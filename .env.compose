POSTGRES_USER=legalos
POSTGRES_PASSWORD=legalos
POSTGRES_DB=legalos
DATABASE_URL=postgresql+psycopg://legalos:legalos@localhost:5432/legalos

# Optional AI / QA config (unused in stub mode)
# FLAGS__ENABLE_GPTQA=false
# QA_MODEL_PRIMARY=gpt-5
# QA_MODEL_FALLBACK=gpt-5-mini
# Note: GPT-5 models above are for orchestration/generative tasks, not embeddings.

# Enable real embeddings providers
# FLAGS__ENABLE_EXTERNAL_AI=false
# AI_PROVIDER=                 # openai | azure-openai | google | mistral | ollama
# AI_ENDPOINT=                 # required for azure-openai & ollama (e.g., https://<resource>.openai.azure.com or http://localhost:11434)
# AI_API_KEY=                  # OpenAI or Azure key
# AI_AZURE_API_VERSION=2024-10-21
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=

# Optional embeddings defaults (distinct from GPT orchestration models)
# EMBEDDINGS__DEFAULT_MODEL=text-embedding-3-large
# EMBEDDINGS__DEFAULT_DIM=3072
