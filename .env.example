ENV=development
DEBUG=true
APP_NAME=legal-os

# Database (SQLite default is used if not set)
# For Postgres via Docker Compose use:
# DATABASE_URL=postgresql+psycopg://legalos:legalos@localhost:5432/legalos
# POSTGRES_USER=legalos
# POSTGRES_PASSWORD=legalos
# POSTGRES_DB=legalos

# Feature flags (nested via double underscore)
# FLAGS__ENABLE_MINIO=false
# FLAGS__ENABLE_REDIS=false
# FLAGS__ENABLE_ELASTICSEARCH=false
# FLAGS__ENABLE_PGVECTOR=false

# Auth
# IMPORTANT: Set a strong secret in production
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AI Provider (optional for QA; stubbed in dev)
# FLAGS__ENABLE_GPTQA=false
# AI_PROVIDER=
# AI_ENDPOINT=
# AI_API_KEY=
# QA_MODEL_PRIMARY=gpt-5
# QA_MODEL_FALLBACK=gpt-5-mini
