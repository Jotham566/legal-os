ENV=development
DEBUG=true
APP_NAME=legal-os

# Database (SQLite default is used if not set)
# For Postgres via Docker Compose use:
# DATABASE_URL=postgresql+psycopg://legalos:legalos@localhost:5432/legalos
# POSTGRES_USER=legalos
# POSTGRES_PASSWORD=legalos
# POSTGRES_DB=legalos

# Feature flags (nested via double underscore)
# FLAGS__ENABLE_MINIO=false
# FLAGS__ENABLE_REDIS=false
# FLAGS__ENABLE_ELASTICSEARCH=false
# FLAGS__ENABLE_PGVECTOR=false

# Auth
# IMPORTANT: Set a strong secret in production
JWT_SECRET=dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# AI and Embeddings Configuration
# Enable to use real providers instead of the deterministic stub.
# FLAGS__ENABLE_EXTERNAL_AI=false
# AI_PROVIDER=                 # one of: openai | azure-openai | google | mistral | ollama

# Provider-specific settings:
# OpenAI (public):
#   AI_API_KEY=               # OpenAI API key
# Azure OpenAI (Azure AI Foundry):
#   AI_ENDPOINT=              # e.g. https://YOUR_RESOURCE_NAME.openai.azure.com
#   AI_API_KEY=               # Azure OpenAI key for the resource
#   AI_AZURE_API_VERSION=2024-10-21
#   Note: pass your embeddings DEPLOYMENT NAME as 'model' in API requests.
# Google Gemini:
#   GOOGLE_API_KEY=
#   Recommended model: gemini-embedding-001
#   You may set dimensions per request (e.g., 768, 1536, 3072)
# Mistral:
#   MISTRAL_API_KEY=
#   Recommended model: mistral-embed (supports output_dimension)
# Ollama (local):
#   AI_ENDPOINT=              # e.g. http://localhost:11434
#   model example: all-minilm or other embedding-capable model

# AI_ENDPOINT=
# AI_API_KEY=
# AI_AZURE_API_VERSION=2024-10-21
# GOOGLE_API_KEY=
# MISTRAL_API_KEY=

# QA (optional)
# FLAGS__ENABLE_GPTQA=false
# QA_MODEL_PRIMARY=gpt-5
# QA_MODEL_FALLBACK=gpt-5-mini

# Embeddings defaults (distinct from orchestration/generative models)
# Note: Embedding models are NOT the same as GPT-5 / GPT-5-mini used in orchestration.
# You can set request-time model/dim in the API payload. Optionally define defaults here:
# EMBEDDINGS__DEFAULT_MODEL=text-embedding-3-large        # or your Azure deployment name, gemini-embedding-001, mistral-embed, etc.
# EMBEDDINGS__DEFAULT_DIM=3072                             # e.g., 768, 1536, 2048, 3072 (provider-dependent)
